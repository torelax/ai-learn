   "source": [
    "# K-V Cache"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "\n",
    "# 假设输入形状为(input_shape)\n",
    "batch_size = 2\n",
    "sequence_length = 5\n",
    "input_shape = (batch_size, sequence_length)\n",
    "\n",
    "# 创建一个上三角矩阵，对角线上方为1，其余为0\n",
    "causal_mask = torch.triu(torch.ones(input_shape[1], input_shape[1]), diagonal=1).bool()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "tensor([[False,  True,  True,  True,  True],\n",
      "        [False, False,  True,  True,  True],\n",
      "        [False, False, False,  True,  True],\n",
      "        [False, False, False, False,  True],\n",
      "        [False, False, False, False, False]])\n"
     ]
    }
   ],
   "source": [
    "print(causal_mask)"
   ]
  }
 ],
